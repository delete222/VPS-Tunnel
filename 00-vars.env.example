# 运行脚本前，把这个文件复制为 00-vars.env，然后填写实际值。
# 不要提交或分享填写后的文件，里面会包含密钥和密码。

# 已托管到 Cloudflare 的域名。请为 CDN_DOMAIN 创建橙云 A/AAAA 记录，
# 指向德国 Oracle VPS 的公网 IP。
CDN_DOMAIN="cdn.example.com"

# 可选的灰云直连域名，给 Reality/HY2 使用，指向德国 Oracle。
DIRECT_DOMAIN="direct.example.com"

# 公网 IP，主要用于防火墙配置和校验提示。
ORACLE_DE_PUBLIC_IP="203.0.113.10"
GCP_US_PUBLIC_IP="198.51.100.20"

# sing-box 包版本。留空表示安装最新版。
SING_BOX_VERSION=""

# 主要客户端身份。
CLIENT_NAME="main"
UUID=""
VLESS_WS_PATH=""
VMESS_WS_PATH=""

# 备用入口协议。
HY2_PASSWORD=""
REALITY_PRIVATE_KEY=""
REALITY_PUBLIC_KEY=""
REALITY_SHORT_ID=""
REALITY_SERVER_NAME="www.cloudflare.com"

# 德国 -> 美国内链。
# 可选值：tailscale、wireguard、ssh-socks
INNER_LINK_MODE="tailscale"

# 如果德国 Oracle VPS 使用 yonggekkk/sing-box-yg，本包可以只补丁它生成的
# 服务端配置，而不是替换整个安装器。
SING_BOX_YG_DIR="/etc/s-box"
SING_BOX_YG_SERVICE_CANDIDATES="sing-box s-box sb"

# Tailscale 模式。在 Tailscale 管理后台生成可复用 auth key。
# Tags 可选；如果你使用 ACL，建议配置 tag。
TAILSCALE_AUTH_KEY_GCP=""
TAILSCALE_AUTH_KEY_ORACLE=""
TAILSCALE_GCP_HOSTNAME="gcp-us-exit"
TAILSCALE_ORACLE_HOSTNAME="oracle-de-entry"
# 可选。简化一键流程里可以留空；两台 VPS 加入 Tailscale 后，
# 德国补丁脚本会根据 TAILSCALE_GCP_HOSTNAME 自动发现。
TAILSCALE_GCP_IP=""

# WireGuard 备用内链。
WG_PORT="51820"
WG_NETWORK="10.66.0.0/24"
WG_GCP_IP="10.66.0.1"
WG_ORACLE_IP="10.66.0.2"
WG_GCP_PRIVATE_KEY=""
WG_GCP_PUBLIC_KEY=""
WG_ORACLE_PRIVATE_KEY=""
WG_ORACLE_PUBLIC_KEY=""

# SSH + SOCKS 备用内链。GCP 上的 SOCKS 只监听 127.0.0.1。
GCP_SSH_USER="ubuntu"
GCP_SSH_HOST="198.51.100.20"
GCP_SSH_PORT="22"
GCP_SSH_KEY_PATH="/root/.ssh/gcp_socks_tunnel"
GCP_SOCKS_USER="relay"
GCP_SOCKS_PASSWORD=""
GCP_SOCKS_PORT="1080"
ORACLE_LOCAL_SOCKS_PORT="11080"

# 德国 Oracle 公网监听端口。
HTTPS_PORT="443"
REALITY_PORT="8443"
HY2_PORT="8443"

# 德国 Oracle 内部服务端口。
VLESS_WS_INTERNAL_PORT="10000"
VMESS_WS_INTERNAL_PORT="10001"
REALITY_INTERNAL_PORT="10002"
HY2_INTERNAL_PORT="10003"

# GCP 内部出口服务端口，只监听 loopback/Tailscale/WireGuard。
GCP_INTERNAL_SOCKS_PORT="1080"
