# Recommended simple path only:
# Germany Oracle: yonggekkk/sing-box-yg entry
# US GCP: sing-box SOCKS exit
# Germany <-> GCP: Tailscale

INNER_LINK_MODE="tailscale"

# Create auth keys in the Tailscale admin console.
# Use reusable or one-off keys as you prefer; the script only needs them once.
TAILSCALE_AUTH_KEY_GCP="tskey-auth-xxxxxxxx"
TAILSCALE_AUTH_KEY_ORACLE="tskey-auth-yyyyyyyy"

# Keep these hostnames unchanged unless you know why you are changing them.
TAILSCALE_GCP_HOSTNAME="gcp-us-exit"
TAILSCALE_ORACLE_HOSTNAME="oracle-de-entry"

# Usually leave empty. The Germany script will auto-detect this after both
# servers join Tailscale.
TAILSCALE_GCP_IP=""

# Internal SOCKS account used only across the Tailscale private link.
GCP_SOCKS_USER="relay"
GCP_SOCKS_PASSWORD="change-this-to-a-long-random-password"

# GCP internal SOCKS port. Do not expose this to the public internet.
GCP_INTERNAL_SOCKS_PORT="1080"

# sing-box release. Leave empty for latest release.
SING_BOX_VERSION=""

# yonggekkk/sing-box-yg default directory on Germany Oracle.
SING_BOX_YG_DIR="/etc/s-box"
SING_BOX_YG_SERVICE_CANDIDATES="sing-box s-box sb"

# Thin-wrapper strategy: pull latest upstream sb.sh at install time, then apply
# our GCP-exit patch afterward. Override only if you want to pin a fork/commit.
UPSTREAM_SB_URL="https://raw.githubusercontent.com/yonggekkk/sing-box-yg/main/sb.sh"
