# Copy this file to 00-vars.env and edit values before running scripts.
# Do not commit or share the edited file: it contains credentials.

# Domain already hosted in Cloudflare. Create an orange-cloud DNS A/AAAA record
# for CDN_DOMAIN pointing to the Germany Oracle VPS public IP.
CDN_DOMAIN="cdn.example.com"

# Optional gray-cloud direct domain for Reality/HY2. Point it to Germany Oracle.
DIRECT_DOMAIN="direct.example.com"

# Public IPs. These are used for firewall and validation messages.
ORACLE_DE_PUBLIC_IP="203.0.113.10"
GCP_US_PUBLIC_IP="198.51.100.20"

# sing-box package version. Leave empty to install the latest release.
SING_BOX_VERSION=""

# Main client identity.
CLIENT_NAME="main"
UUID=""
VLESS_WS_PATH=""
VMESS_WS_PATH=""

# Backup entry protocols.
HY2_PASSWORD=""
REALITY_PRIVATE_KEY=""
REALITY_PUBLIC_KEY=""
REALITY_SHORT_ID=""
REALITY_SERVER_NAME="www.cloudflare.com"

# Germany -> US internal link.
# Valid values: tailscale, wireguard, ssh-socks
INNER_LINK_MODE="tailscale"

# If you use yonggekkk/sing-box-yg on the Germany Oracle VPS, this kit can
# patch its generated server configs instead of replacing the whole installer.
SING_BOX_YG_DIR="/etc/s-box"
SING_BOX_YG_SERVICE_CANDIDATES="sing-box s-box sb"

# Tailscale mode. Generate reusable auth keys in the Tailscale admin console.
# Tags are optional, but recommended if ACLs are used.
TAILSCALE_AUTH_KEY_GCP=""
TAILSCALE_AUTH_KEY_ORACLE=""
TAILSCALE_GCP_HOSTNAME="gcp-us-exit"
TAILSCALE_ORACLE_HOSTNAME="oracle-de-entry"
# Optional. Leave empty in the simple one-click flow; the Germany patch will
# try to detect it from TAILSCALE_GCP_HOSTNAME after both VPS join Tailscale.
TAILSCALE_GCP_IP=""

# WireGuard fallback.
WG_PORT="51820"
WG_NETWORK="10.66.0.0/24"
WG_GCP_IP="10.66.0.1"
WG_ORACLE_IP="10.66.0.2"
WG_GCP_PRIVATE_KEY=""
WG_GCP_PUBLIC_KEY=""
WG_ORACLE_PRIVATE_KEY=""
WG_ORACLE_PUBLIC_KEY=""

# SSH + SOCKS fallback. SOCKS stays bound to 127.0.0.1 on GCP.
GCP_SSH_USER="ubuntu"
GCP_SSH_HOST="198.51.100.20"
GCP_SSH_PORT="22"
GCP_SSH_KEY_PATH="/root/.ssh/gcp_socks_tunnel"
GCP_SOCKS_USER="relay"
GCP_SOCKS_PASSWORD=""
GCP_SOCKS_PORT="1080"
ORACLE_LOCAL_SOCKS_PORT="11080"

# Public listener ports on Germany Oracle.
HTTPS_PORT="443"
REALITY_PORT="8443"
HY2_PORT="8443"

# Internal service ports on Germany Oracle.
VLESS_WS_INTERNAL_PORT="10000"
VMESS_WS_INTERNAL_PORT="10001"
REALITY_INTERNAL_PORT="10002"
HY2_INTERNAL_PORT="10003"

# Internal exit service port on GCP. It listens only on loopback/Tailscale/WG.
GCP_INTERNAL_SOCKS_PORT="1080"
